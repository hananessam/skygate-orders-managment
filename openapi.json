{
  "openapi": "3.0.0",
  "paths": {
    "/api": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Service is running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "example": "Hello World!"
                }
              }
            }
          }
        },
        "summary": "Health check endpoint",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/products": {
      "get": {
        "operationId": "ProductController_findAll",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Products retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProductResponseDto"
                  }
                }
              }
            }
          }
        },
        "summary": "Get all available products",
        "tags": [
          "Products"
        ]
      }
    },
    "/api/products/{id}": {
      "get": {
        "operationId": "ProductController_findOne",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Product UUID",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductResponseDto"
                }
              }
            }
          },
          "404": {
            "description": "Product not found"
          }
        },
        "summary": "Get a product by id",
        "tags": [
          "Products"
        ]
      }
    },
    "/api/orders": {
      "post": {
        "operationId": "OrderController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Validation failed or insufficient stock"
          },
          "401": {
            "description": "Invalid or missing access token"
          },
          "404": {
            "description": "One or more products were not found"
          },
          "409": {
            "description": "Concurrent stock update conflict, please retry"
          }
        },
        "security": [
          {
            "access-token": []
          }
        ],
        "summary": "Create a new order",
        "tags": [
          "Orders"
        ]
      },
      "get": {
        "operationId": "OrderController_findAll",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "default": 1,
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "maximum": 100,
              "default": 10,
              "example": 10,
              "type": "number"
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "completed",
                "cancelled"
              ]
            }
          },
          {
            "name": "startDate",
            "required": false,
            "in": "query",
            "description": "Include orders created at or after this ISO date",
            "schema": {
              "example": "2026-01-01T00:00:00.000Z",
              "type": "string"
            }
          },
          {
            "name": "endDate",
            "required": false,
            "in": "query",
            "description": "Include orders created at or before this ISO date",
            "schema": {
              "example": "2026-12-31T23:59:59.999Z",
              "type": "string"
            }
          },
          {
            "name": "minTotalAmount",
            "required": false,
            "in": "query",
            "description": "Minimum order total amount",
            "schema": {
              "minimum": 0,
              "example": 100,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Orders retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedOrdersResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Invalid filter values"
          },
          "401": {
            "description": "Invalid or missing access token"
          }
        },
        "security": [
          {
            "access-token": []
          }
        ],
        "summary": "List orders with pagination and filters",
        "tags": [
          "Orders"
        ]
      }
    },
    "/api/auth/register": {
      "post": {
        "operationId": "AuthController_register",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User registered successfully with access and refresh tokens",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              }
            }
          }
        },
        "summary": "Register a new user account",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User authenticated successfully with access and refresh tokens",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Invalid email or password"
          }
        },
        "summary": "Login using email and password",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/refresh": {
      "post": {
        "operationId": "AuthController_refresh",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Tokens refreshed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid refresh token"
          }
        },
        "security": [
          {
            "access-token": []
          }
        ],
        "summary": "Refresh access and refresh tokens",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [],
        "responses": {
          "204": {
            "description": "Logged out successfully"
          },
          "401": {
            "description": "Invalid or missing access token"
          }
        },
        "security": [
          {
            "access-token": []
          }
        ],
        "summary": "Logout current user session",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/auth/me": {
      "get": {
        "operationId": "AuthController_me",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Current user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthUserDto"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing access token"
          }
        },
        "security": [
          {
            "access-token": []
          }
        ],
        "summary": "Get current authenticated user",
        "tags": [
          "Auth"
        ]
      }
    }
  },
  "info": {
    "title": "SkyGate Orders Management API",
    "description": "REST API documentation for SkyGate Orders Management",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Default server"
    }
  ],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "ProductResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "4e5c8892-00e0-462c-9e96-d467f7f590a4"
          },
          "sku": {
            "type": "string",
            "example": "SKU1001"
          },
          "name": {
            "type": "string",
            "example": "Noise Cancelling Headphones"
          },
          "price": {
            "type": "number",
            "example": 199.99
          },
          "stockQuantity": {
            "type": "number",
            "example": 25
          }
        },
        "required": [
          "id",
          "sku",
          "name",
          "price",
          "stockQuantity"
        ]
      },
      "OrderItemInputDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "example": "4e5c8892-00e0-462c-9e96-d467f7f590a4",
            "description": "Product UUID"
          },
          "quantity": {
            "type": "number",
            "example": 2,
            "minimum": 1,
            "description": "Quantity to order"
          }
        },
        "required": [
          "productId",
          "quantity"
        ]
      },
      "CreateOrderDto": {
        "type": "object",
        "properties": {
          "items": {
            "description": "List of products to include in the order",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemInputDto"
            }
          }
        },
        "required": [
          "items"
        ]
      },
      "OrderItemResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "cc8eb39f-22fe-4eaf-a80f-5bc4ce45fcc8"
          },
          "orderId": {
            "type": "string",
            "example": "9dd1e6e2-420f-41ec-9ea8-2eaa64ea4700"
          },
          "productId": {
            "type": "string",
            "example": "4e5c8892-00e0-462c-9e96-d467f7f590a4"
          },
          "quantity": {
            "type": "number",
            "example": 2
          },
          "priceAtPurchase": {
            "type": "number",
            "example": 199.99
          }
        },
        "required": [
          "id",
          "orderId",
          "productId",
          "quantity",
          "priceAtPurchase"
        ]
      },
      "OrderResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "9dd1e6e2-420f-41ec-9ea8-2eaa64ea4700"
          },
          "userId": {
            "type": "number",
            "example": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "completed",
              "cancelled"
            ],
            "example": "pending"
          },
          "totalAmount": {
            "type": "number",
            "example": 399.98
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemResponseDto"
            }
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-05-23T12:00:00.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-05-23T12:00:00.000Z"
          }
        },
        "required": [
          "id",
          "userId",
          "status",
          "totalAmount",
          "items",
          "createdAt",
          "updatedAt"
        ]
      },
      "PaginationMetaDto": {
        "type": "object",
        "properties": {
          "page": {
            "type": "number",
            "example": 1
          },
          "limit": {
            "type": "number",
            "example": 10
          },
          "totalPages": {
            "type": "number",
            "example": 1
          },
          "totalItems": {
            "type": "number",
            "example": 5
          }
        },
        "required": [
          "page",
          "limit",
          "totalPages",
          "totalItems"
        ]
      },
      "PaginatedOrdersResponseDto": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderResponseDto"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMetaDto"
          }
        },
        "required": [
          "data",
          "meta"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@example.com"
          },
          "password": {
            "type": "string",
            "example": "Admin12345!",
            "minLength": 8
          },
          "name": {
            "type": "string",
            "example": "Admin"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1
          },
          "email": {
            "type": "string",
            "example": "admin@example.com"
          },
          "name": {
            "type": "string",
            "example": "Admin",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-05-23T12:00:00.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-05-23T12:00:00.000Z"
          }
        },
        "required": [
          "id",
          "email",
          "createdAt",
          "updatedAt"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.access.payload.signature"
          },
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.refresh.payload.signature"
          },
          "user": {
            "$ref": "#/components/schemas/AuthUserDto"
          }
        },
        "required": [
          "accessToken",
          "refreshToken",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@example.com"
          },
          "password": {
            "type": "string",
            "example": "Admin12345!"
          }
        },
        "required": [
          "email",
          "password"
        ]
      }
    }
  }
}